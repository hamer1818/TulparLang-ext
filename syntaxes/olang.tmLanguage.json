{
  "scopeName": "source.olang",
  "name": "Olang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#constants" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        { "name": "comment.line.double-slash.olang", "match": "//.*$" },
        { "name": "comment.block.olang", "begin": "/\\*", "end": "\\*/" }
      ]
    },
    "strings": {
      "patterns": [
        { "name": "string.quoted.double.olang", "begin": "\"", "end": "\"", "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.olang" }] },
        { "name": "string.quoted.single.olang", "begin": "'", "end": "'", "patterns": [{ "match": "\\\\.", "name": "constant.character.escape.olang" }] }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.olang", "match": "\\b\\d+\\.\\d+\\b" },
        { "name": "constant.numeric.olang", "match": "\\b\\d+\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        { "name": "keyword.control.olang", "match": "\\b(?:if|else|for|while|return|break|continue|in)\\b" },
        { "name": "keyword.other.olang", "match": "\\b(?:func)\\b" }
      ]
    },
    "types": {
      "patterns": [
        { "name": "storage.type.olang", "match": "\\b(?:int|float|str|bool|array|arrayInt|arrayFloat|arrayStr|arrayBool|arrayJson)\\b" }
      ]
    },
    "functions": {
      "patterns": [
        { "name": "entity.name.function.olang", "match": "\\b(?:print|input|inputInt|inputFloat|length|push|pop|range|toInt|toFloat|toString|toBool|abs|sqrt|cbrt|pow|hypot|floor|ceil|round|trunc|sin|cos|tan|asin|acos|atan|atan2|sinh|cosh|tanh|exp|log|log10|log2|min|max|random|randint|fmod)\\b" }
      ]
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.olang", "match": "\\b(?:true|false)\\b" }
      ]
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.logical.olang", "match": "&&|\\|\\||!" },
        { "name": "keyword.operator.comparison.olang", "match": "==|!=|<=|>=|<|>" },
        { "name": "keyword.operator.arithmetic.olang", "match": "\\+\\+|--|\\+=|-=|\\*=|/=|\\+|-|\\*|/|%" },
        { "name": "keyword.operator.assignment.olang", "match": "=" }
      ]
    }
  }
}
