{
  "scopeName": "source.tulpar",
  "name": "Tulpar",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.tulpar",
          "match": "//.*$"
        },
        {
          "name": "comment.block.tulpar",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.tulpar",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.tulpar"
            }
          ]
        },
        {
          "name": "string.quoted.single.tulpar",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "match": "\\\\.",
              "name": "constant.character.escape.tulpar"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.tulpar",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.tulpar",
          "match": "\\b(?:if|else|for|while|return|break|continue|in|func|import|type|try|catch|finally|throw)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.tulpar",
          "match": "\\b(?:int|float|str|bool|bigint|json|array|arrayInt|arrayFloat|arrayStr|arrayBool|arrayJson)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.tulpar",
          "match": "\\b(?:print|input|inputInt|inputFloat|length|push|pop|range|toInt|toFloat|toString|toBool|toJson|fromJson|abs|sqrt|cbrt|pow|hypot|floor|ceil|round|trunc|sin|cos|tan|asin|acos|atan|atan2|sinh|cosh|tanh|exp|log|log10|log2|min|max|random|randint|fmod|mod|upper|lower|toUpper|toLower|capitalize|reverse|trim|replace|contains|startsWith|endsWith|indexOf|index_of|count|substring|repeat|split|join|isEmpty|isDigit|isAlpha|file_read|file_write|file_delete|file_exists|read_file|write_file|append_file|timestamp|time_ms|clock_ms|sleep|thread_create|mutex_create|mutex_lock|mutex_unlock|http_parse_request|http_create_response|get|post|listen|route_get|route_post|api_get|api_post|api_run|api_json_response|db_open|db_close|db_query|db_execute)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.tulpar",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.logical.tulpar",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.comparison.tulpar",
          "match": "==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.arithmetic.tulpar",
          "match": "\\+\\+|--|\\+=|-=|\\*=|/=|\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.assignment.tulpar",
          "match": "="
        }
      ]
    }
  }
}