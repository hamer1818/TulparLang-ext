{
  "name": "vscode-tulpar",
  "displayName": "Tulpar",
  "publisher": "your-name",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.60.0"
  },
  "description": "Tulpar language support for VS Code — syntax highlighting, snippets and a Run command.",
  "main": "./src/extension.js",
  "scripts": {
    "test": "echo \"No tests\" && exit 0"
  },
  "contributes": {
    "languages": [
      {
        "id": "tulpar",
        "aliases": ["Tulpar", "tulpar"],
        "extensions": [".tpr"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "tulpar",
        "scopeName": "source.tulpar",
        "path": "./syntaxes/tulpar.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "tulpar",
        "path": "./snippets/tulpar.json"
      }
    ],
    "commands": [
      {
        "command": "tulpar.runFile",
        "title": "Run Tulpar File"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Tulpar",
      "properties": {
        "tulpar.runCommand": {
          "type": "string",
          "default": "tulpar run ${file}",
          "description": "Command used to run a Tulpar file. Use ${file} to insert the active file path."
        }
      }
    }
  },
  "activationEvents": [
    "onCommand:tulpar.runFile",
    "onLanguage:tulpar"
  ],
  "dependencies": {}
}
