{
  "name": "vscode-tulpar",
  "displayName": "Tulpar",
  "publisher": "hamer1818",
  "version": "0.0.3",
  "icon": "tulpar.webp",
  "repository": {
    "type": "git",
    "url": "https://github.com/hamer1818/TulparLang-ext.git"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "description": "Tulpar language support for VS Code — syntax highlighting, snippets and a Run command.",
  "main": "./src/extension.js",
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "tulpar",
    "programming",
    "language",
    "syntax",
    "highlighting",
    "snippets"
  ],
  "homepage": "https://github.com/hamer1818/TulparLang-ext",
  "bugs": {
    "url": "https://github.com/hamer1818/TulparLang-ext/issues"
  },
  "license": "MIT",
  "scripts": {
    "test": "echo \"No tests\" && exit 0"
  },
  "contributes": {
    "languages": [
      {
        "id": "tulpar",
        "aliases": [
          "Tulpar",
          "tulpar"
        ],
        "extensions": [
          ".tpr"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./tulpar.webp",
          "dark": "./tulpar.webp"
        }
      }
    ],
    "grammars": [
      {
        "language": "tulpar",
        "scopeName": "source.tulpar",
        "path": "./syntaxes/tulpar.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "tulpar",
        "path": "./snippets/tulpar.json"
      }
    ],
    "commands": [
      {
        "command": "tulpar.runFile",
        "title": "Run Tulpar File"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Tulpar",
      "properties": {
        "tulpar.runCommand": {
          "type": "string",
          "default": "tulpar ${file}",
          "description": "Command used to run a Tulpar file. Use ${file} to insert the active file path. Examples: 'tulpar ${file}' (VM mode, default), 'tulpar --aot ${file} out' (AOT compilation), 'tulpar --repl' (interactive REPL)."
        }
      }
    }
  },
  "activationEvents": [
    "onCommand:tulpar.runFile",
    "onLanguage:tulpar"
  ],
  "dependencies": {}
}