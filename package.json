{
  "name": "vscode-tulpar",
  "displayName": "Tulpar",
  "publisher": "hamer1818",
  "version": "0.3.0",
  "icon": "tulpar.webp",
  "repository": {
    "type": "git",
    "url": "https://github.com/hamer1818/TulparLang-ext.git"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "description": "Tulpar language support for VS Code — syntax highlighting, snippets, run/build/REPL commands and inline error diagnostics.",
  "main": "./src/extension.js",
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "keywords": [
    "tulpar",
    "tulparlang",
    "programming",
    "language",
    "syntax",
    "highlighting",
    "snippets",
    "llvm",
    "aot"
  ],
  "homepage": "https://github.com/hamer1818/TulparLang-ext",
  "bugs": {
    "url": "https://github.com/hamer1818/TulparLang-ext/issues"
  },
  "license": "MIT",
  "scripts": {
    "test": "echo \"No tests\" && exit 0"
  },
  "contributes": {
    "languages": [
      {
        "id": "tulpar",
        "aliases": [
          "Tulpar",
          "tulpar"
        ],
        "extensions": [
          ".tpr"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./tulpar.webp",
          "dark": "./tulpar.webp"
        }
      }
    ],
    "grammars": [
      {
        "language": "tulpar",
        "scopeName": "source.tulpar",
        "path": "./syntaxes/tulpar.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "tulpar",
        "path": "./snippets/tulpar.json"
      }
    ],
    "commands": [
      {
        "command": "tulpar.runFile",
        "title": "Tulpar: Run File",
        "icon": "$(play)"
      },
      {
        "command": "tulpar.runVM",
        "title": "Tulpar: Run with VM"
      },
      {
        "command": "tulpar.buildAOT",
        "title": "Tulpar: Build (AOT)"
      },
      {
        "command": "tulpar.runAOT",
        "title": "Tulpar: Build & Run (AOT)"
      },
      {
        "command": "tulpar.runRepl",
        "title": "Tulpar: Open REPL"
      },
      {
        "command": "tulpar.checkFile",
        "title": "Tulpar: Check File (Diagnostics)"
      }
    ],
    "menus": {
      "editor/title/run": [
        {
          "command": "tulpar.runFile",
          "when": "resourceLangId == tulpar",
          "group": "navigation@1"
        },
        {
          "command": "tulpar.buildAOT",
          "when": "resourceLangId == tulpar",
          "group": "navigation@2"
        }
      ],
      "editor/context": [
        {
          "command": "tulpar.runFile",
          "when": "resourceLangId == tulpar",
          "group": "tulpar@1"
        },
        {
          "command": "tulpar.buildAOT",
          "when": "resourceLangId == tulpar",
          "group": "tulpar@2"
        },
        {
          "command": "tulpar.checkFile",
          "when": "resourceLangId == tulpar",
          "group": "tulpar@3"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "Tulpar",
      "properties": {
        "tulpar.executablePath": {
          "type": "string",
          "default": "tulpar",
          "description": "Path to the Tulpar executable. Use absolute path if 'tulpar' is not on PATH (e.g. 'D:/yazilim/Tulpar/tulpar.exe')."
        },
        "tulpar.runCommand": {
          "type": "string",
          "default": "",
          "description": "Optional override for the default Run command. Use ${file} for the active file. If empty, the default command is built from 'tulpar.executablePath' and runs the file in VM mode."
        },
        "tulpar.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline diagnostics (errors/warnings shown in the Problems panel) when a Tulpar file is saved."
        },
        "tulpar.diagnostics.runOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Re-run the diagnostic check whenever a Tulpar file is saved. Disable for very large files where the check is too slow."
        },
        "tulpar.aot.outputName": {
          "type": "string",
          "default": "",
          "description": "Output executable name for 'Build (AOT)'. If empty, derives from the source file name (script.tpr → script[.exe])."
        }
      }
    }
  },
  "activationEvents": [
    "onLanguage:tulpar",
    "onCommand:tulpar.runFile",
    "onCommand:tulpar.runVM",
    "onCommand:tulpar.buildAOT",
    "onCommand:tulpar.runAOT",
    "onCommand:tulpar.runRepl",
    "onCommand:tulpar.checkFile"
  ],
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  }
}
