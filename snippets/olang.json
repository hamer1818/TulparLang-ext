{
  "Print Statement": {
    "prefix": "print",
    "body": ["print($1);"],
    "description": "Print statement"
  },
  "Variable Declaration (int)": {
    "prefix": "oint",
    "body": ["int ${1:name} = ${2:0};"],
    "description": "Integer variable declaration"
  },
  "Variable Declaration (float)": {
    "prefix": "ofloat",
    "body": ["float ${1:name} = ${2:0.0};"],
    "description": "Float variable declaration"
  },
  "Variable Declaration (str)": {
    "prefix": "ostr",
    "body": ["str ${1:name} = \"${2}\";"],
    "description": "String variable declaration"
  },
  "Variable Declaration (bool)": {
    "prefix": "obool",
    "body": ["bool ${1:name} = ${2:true};"],
    "description": "Boolean variable declaration"
  },
  "Array (mixed)": {
    "prefix": "oarray",
    "body": ["array ${1:name} = [${2}];"],
    "description": "Mixed type array"
  },
  "Array (int)": {
    "prefix": "oarrayint",
    "body": ["arrayInt ${1:name} = [${2}];"],
    "description": "Integer array"
  },
  "Array (str)": {
    "prefix": "oarraystr",
    "body": ["arrayStr ${1:name} = [${2}];"],
    "description": "String array"
  },
  "If statement": {
    "prefix": "oif",
    "body": ["if (${1:condition}) {", "  $0", "}"],
    "description": "If statement"
  },
  "If-Else statement": {
    "prefix": "oifelse",
    "body": ["if (${1:condition}) {", "  $2", "} else {", "  $0", "}"],
    "description": "If-Else statement"
  },
  "While loop": {
    "prefix": "owhile",
    "body": ["while (${1:condition}) {", "  $0", "}"],
    "description": "While loop"
  },
  "For loop (C-style)": {
    "prefix": "ofor",
    "body": ["for (int ${1:i} = 0; ${1:i} < ${2:10}; ${1:i}++) {", "  $0", "}"],
    "description": "C-style for loop"
  },
  "For-in loop (range)": {
    "prefix": "oforin",
    "body": ["for (${1:i} in range(${2:10})) {", "  $0", "}"],
    "description": "For-in loop with range"
  },
  "Function": {
    "prefix": "ofunc",
    "body": ["func ${1:name}(${2:params}) {", "  $0", "}"],
    "description": "Function declaration"
  },
  "Function with return": {
    "prefix": "ofuncr",
    "body": ["func ${1:name}(${2:params}) {", "  return ${3:value};", "}"],
    "description": "Function with return"
  },
  "Input (string)": {
    "prefix": "oinput",
    "body": ["str ${1:name} = input(\"${2:prompt}: \");"],
    "description": "String input"
  },
  "Input (int)": {
    "prefix": "oinputint",
    "body": ["int ${1:name} = inputInt(\"${2:prompt}: \");"],
    "description": "Integer input"
  },
  "Comment block": {
    "prefix": "ocomment",
    "body": [
      "// ----------------------------------------",
      "// ${1:SECTION NAME}",
      "// ----------------------------------------"
    ],
    "description": "Section comment block"
  },
  
  "Square Root": {
    "prefix": "osqrt",
    "body": ["sqrt(${1:value})"],
    "description": "Square root function"
  },
  "Power": {
    "prefix": "opow",
    "body": ["pow(${1:base}, ${2:exponent})"],
    "description": "Power function (x^y)"
  },
  "Absolute Value": {
    "prefix": "oabs",
    "body": ["abs(${1:value})"],
    "description": "Absolute value function"
  },
  "Floor": {
    "prefix": "ofloor",
    "body": ["floor(${1:value})"],
    "description": "Floor function (round down)"
  },
  "Ceiling": {
    "prefix": "oceil",
    "body": ["ceil(${1:value})"],
    "description": "Ceiling function (round up)"
  },
  "Round": {
    "prefix": "oround",
    "body": ["round(${1:value})"],
    "description": "Round to nearest integer"
  },
  "Sin": {
    "prefix": "osin",
    "body": ["sin(${1:radians})"],
    "description": "Sine function (radians)"
  },
  "Cos": {
    "prefix": "ocos",
    "body": ["cos(${1:radians})"],
    "description": "Cosine function (radians)"
  },
  "Tan": {
    "prefix": "otan",
    "body": ["tan(${1:radians})"],
    "description": "Tangent function (radians)"
  },
  "Log": {
    "prefix": "olog",
    "body": ["log(${1:value})"],
    "description": "Natural logarithm (ln)"
  },
  "Log10": {
    "prefix": "olog10",
    "body": ["log10(${1:value})"],
    "description": "Base-10 logarithm"
  },
  "Exp": {
    "prefix": "oexp",
    "body": ["exp(${1:value})"],
    "description": "Exponential function (e^x)"
  },
  "Random": {
    "prefix": "orandom",
    "body": ["random()"],
    "description": "Random number between 0 and 1"
  },
  "Random Integer": {
    "prefix": "orandint",
    "body": ["randint(${1:min}, ${2:max})"],
    "description": "Random integer in range [min, max]"
  },
  "Min": {
    "prefix": "omin",
    "body": ["min(${1:values})"],
    "description": "Minimum value"
  },
  "Max": {
    "prefix": "omax",
    "body": ["max(${1:values})"],
    "description": "Maximum value"
  },
  "Pythagorean": {
    "prefix": "opythag",
    "body": ["sqrt(pow(${1:a}, 2) + pow(${2:b}, 2))"],
    "description": "Pythagorean theorem: √(a²+b²)"
  },
  "Degrees to Radians": {
    "prefix": "orad",
    "body": ["${1:degrees} * 3.14159 / 180.0"],
    "description": "Convert degrees to radians"
  },
  
  "String to Uppercase": {
    "prefix": "oupper",
    "body": ["upper(${1:string})"],
    "description": "Convert string to uppercase"
  },
  "String to Lowercase": {
    "prefix": "olower",
    "body": ["lower(${1:string})"],
    "description": "Convert string to lowercase"
  },
  "Trim String": {
    "prefix": "otrim",
    "body": ["trim(${1:string})"],
    "description": "Remove leading and trailing whitespace"
  },
  "Replace String": {
    "prefix": "oreplace",
    "body": ["replace(${1:string}, \"${2:old}\", \"${3:new}\")"],
    "description": "Replace substring in string"
  },
  "Contains Substring": {
    "prefix": "ocontains",
    "body": ["contains(${1:string}, \"${2:substring}\")"],
    "description": "Check if string contains substring"
  },
  "Substring": {
    "prefix": "osubstring",
    "body": ["substring(${1:string}, ${2:start}, ${3:end})"],
    "description": "Extract substring from string"
  },
  "Split String": {
    "prefix": "osplit",
    "body": ["split(${1:string}, \"${2:delimiter}\")"],
    "description": "Split string into array by delimiter"
  },
  "Join Array": {
    "prefix": "ojoin",
    "body": ["join(\"${1:separator}\", ${2:array})"],
    "description": "Join array elements into string"
  },
  "Reverse String": {
    "prefix": "oreverse",
    "body": ["reverse(${1:string})"],
    "description": "Reverse string characters"
  },
  "Capitalize String": {
    "prefix": "ocapitalize",
    "body": ["capitalize(${1:string})"],
    "description": "Capitalize first letter"
  }
}
