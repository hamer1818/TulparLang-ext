{
  "Main function": {
    "prefix": "tmain",
    "body": [
      "func main() {",
      "  $0",
      "}"
    ],
    "description": "Tulpar main function"
  },
  "Typed function (int return)": {
    "prefix": "tfunci",
    "body": [
      "func ${1:name}(${2:int x}): int {",
      "  $0",
      "  return ${3:0};",
      "}"
    ],
    "description": "Function with explicit `: int` return type — triggers Tulpar's native AOT codegen path"
  },
  "Function": {
    "prefix": "tfunc",
    "body": [
      "func ${1:name}(${2:params}) {",
      "  $0",
      "}"
    ],
    "description": "Function definition"
  },
  "If statement": {
    "prefix": "tif",
    "body": [
      "if (${1:condition}) {",
      "  $0",
      "}"
    ],
    "description": "If statement"
  },
  "If/else": {
    "prefix": "tifelse",
    "body": [
      "if (${1:condition}) {",
      "  ${2:// then}",
      "} else {",
      "  ${0:// else}",
      "}"
    ],
    "description": "If/else"
  },
  "For loop (int counter)": {
    "prefix": "tfor",
    "body": [
      "for (int ${1:i} = 0; ${1:i} < ${2:count}; ${1:i} = ${1:i} + 1) {",
      "  $0",
      "}"
    ],
    "description": "For loop with int counter (works on both VM and AOT paths)"
  },
  "For-in loop": {
    "prefix": "tforin",
    "body": [
      "for (${1:item} in ${2:collection}) {",
      "  $0",
      "}"
    ],
    "description": "For-in loop over a collection"
  },
  "While loop": {
    "prefix": "twhile",
    "body": [
      "while (${1:condition}) {",
      "  $0",
      "}"
    ],
    "description": "While loop"
  },
  "Import": {
    "prefix": "timport",
    "body": [
      "import \"${1:lib/router.tpr}\";"
    ],
    "description": "Import statement"
  },
  "Type Definition": {
    "prefix": "ttype",
    "body": [
      "type ${1:Name} {",
      "  ${2:int} ${3:field};",
      "  $0",
      "}"
    ],
    "description": "Custom type definition"
  },
  "Try-Catch-Finally": {
    "prefix": "ttry",
    "body": [
      "try {",
      "  ${1:// code}",
      "} catch (${2:e}) {",
      "  ${3:print(\"Error: \" + e);}",
      "} finally {",
      "  ${0:// cleanup}",
      "}"
    ],
    "description": "Try/catch/finally block"
  },
  "JSON Object": {
    "prefix": "tjson",
    "body": [
      "json ${1:obj} = {",
      "  \"${2:key}\": ${3:value}",
      "};"
    ],
    "description": "JSON object literal"
  },
  "JSON Array": {
    "prefix": "tjsonarr",
    "body": [
      "json ${1:items} = [];",
      "push(${1:items}, ${2:value});"
    ],
    "description": "Empty JSON array + push"
  },
  "Read File": {
    "prefix": "tread",
    "body": [
      "str ${1:content} = read_file(\"${2:file.txt}\");"
    ],
    "description": "Read file content"
  },
  "Write File": {
    "prefix": "twrite",
    "body": [
      "write_file(\"${1:file.txt}\", ${2:content});"
    ],
    "description": "Write content to file"
  },
  "Threading Example": {
    "prefix": "tthread",
    "body": [
      "mutex lock = mutex_create();",
      "int counter = 0;",
      "",
      "func ${1:worker}() {",
      "  mutex_lock(lock);",
      "  counter = counter + 1;",
      "  mutex_unlock(lock);",
      "}",
      "",
      "thread_create(\"${1:worker}\", null);"
    ],
    "description": "Threading with mutex"
  },
  "Wings HTTP Route": {
    "prefix": "twings",
    "body": [
      "import \"wings\";",
      "",
      "func ${1:handler}() {",
      "  // _request fields: method, path, raw_path, version,",
      "  // query (json), headers (json), body (str)",
      "  return {\"message\": \"${2:Hello}\"};",
      "}",
      "",
      "get(\"/${3:path}\", \"${1:handler}\");",
      "listen(${4:3000});"
    ],
    "description": "Wings HTTP route + listener"
  },
  "HTTP parse request": {
    "prefix": "thttp",
    "body": [
      "json req = http_parse_request(${1:raw});",
      "str method = req[\"method\"];",
      "str path = req[\"path\"];",
      "str body = req[\"body\"];",
      "json query = req[\"query\"];",
      "json headers = req[\"headers\"];"
    ],
    "description": "Parse a raw HTTP request via the native runtime builtin"
  },
  "HTTP response": {
    "prefix": "thresp",
    "body": [
      "str resp = http_create_response(${1:200}, \"${2:application/json}\", ${3:body});"
    ],
    "description": "Build an HTTP response string (3-arg form)"
  },
  "HTTP response with headers": {
    "prefix": "threspx",
    "body": [
      "json headers = {",
      "  \"Access-Control-Allow-Origin\": \"*\",",
      "  \"$1\": \"$2\"",
      "};",
      "str resp = http_create_response(${3:200}, \"${4:application/json}\", ${5:body}, headers);"
    ],
    "description": "Build an HTTP response with custom headers (CORS, Set-Cookie, ...)"
  },
  "Router App (lib/router.tpr)": {
    "prefix": "trouter",
    "body": [
      "import \"lib/router.tpr\";",
      "",
      "func ${1:hello}() {",
      "  // _request[\"params\"][\"id\"] for /:id captures",
      "  return { \"message\": \"${2:Hello, world!}\" };",
      "}",
      "",
      "route_get(\"/${3:path/:id}\", \"${1:hello}\");",
      "listen(${4:8080});"
    ],
    "description": "Router app with one GET route (Express-style :param captures)"
  },
  "Path match": {
    "prefix": "tpath",
    "body": [
      "json m = path_match(\"${1:/users/:id}\", ${2:request_path});",
      "if (m[\"matched\"]) {",
      "  json params = m[\"params\"];",
      "  $0",
      "}"
    ],
    "description": "Match a request path against an Express-style pattern (native, fast)"
  },
  "Test framework": {
    "prefix": "ttest",
    "body": [
      "import \"test\";",
      "",
      "func ${1:basic_math}() {",
      "  assert_eq_int(1 + 1, 2);",
      "}",
      "",
      "test(\"${2:basic math}\", \"${1:basic_math}\");",
      "test_summary();"
    ],
    "description": "Stub a unit test file (uses lib/test.tpr framework)"
  },
  "Assert throws": {
    "prefix": "tthrows",
    "body": [
      "func ${1:bad_input}() {",
      "  throw \"${2:error message}\";",
      "}",
      "",
      "func tc_${1:bad_input}() {",
      "  assert_throws(\"${1:bad_input}\", \"${3:error}\");",
      "}",
      "",
      "test(\"${1:bad_input} throws\", \"tc_${1:bad_input}\");"
    ],
    "description": "Test that a handler throws (assert_throws + handler stub)"
  },
  "Tulpar API (FastAPI-style)": {
    "prefix": "tapi",
    "body": [
      "import \"lib/tulpar_api.tpr\";",
      "",
      "api_init(\"${1:My API}\", \"${2:1.0.0}\");",
      "api_use(\"logger\");",
      "api_use(\"cors\");",
      "",
      "func ${3:list_items}(json req) {",
      "  return api_json_response({ \"items\": [] });",
      "}",
      "",
      "api_get(\"/${4:items}\", \"${3:list_items}\");",
      "api_run(${5:8080});"
    ],
    "description": "Tulpar API endpoint scaffold"
  },
  "Socket Server": {
    "prefix": "tsocket",
    "body": [
      "import \"lib/socket.tpr\";",
      "",
      "int sock = socket_create();",
      "socket_bind(sock, \"${1:0.0.0.0}\", ${2:9000});",
      "socket_listen(sock, ${3:5});",
      "",
      "while (true) {",
      "  int client = socket_accept(sock);",
      "  $0",
      "  socket_close(client);",
      "}"
    ],
    "description": "TCP socket server skeleton"
  },
  "Async block": {
    "prefix": "tasync",
    "body": [
      "import \"async\";",
      "",
      "async_run(func() {",
      "  $0",
      "});"
    ],
    "description": "Run code asynchronously"
  },
  "Middleware": {
    "prefix": "tmw",
    "body": [
      "import \"middleware\";",
      "",
      "func ${1:logger}(json req, json next) {",
      "  print(\"[\" + req[\"method\"] + \"] \" + req[\"path\"]);",
      "  return call(next);",
      "}",
      "",
      "middleware_use(\"${1:logger}\");"
    ],
    "description": "HTTP middleware function"
  },
  "Database CRUD": {
    "prefix": "tdb",
    "body": [
      "int db = db_open(\"${1:app.db}\");",
      "db_execute(db, \"CREATE TABLE IF NOT EXISTS ${2:items} (id INTEGER PRIMARY KEY, name TEXT)\");",
      "db_execute(db, \"INSERT INTO ${2:items} (name) VALUES ('${3:Alice}')\");",
      "json rows = db_query(db, \"SELECT * FROM ${2:items}\");",
      "for (json row in rows) {",
      "  print(row);",
      "}",
      "db_close(db);"
    ],
    "description": "SQLite CRUD via embedded driver"
  },
  "Print": {
    "prefix": "tp",
    "body": ["print(${1:value});"],
    "description": "print()"
  },
  "Print + toString": {
    "prefix": "tps",
    "body": ["print(toString(${1:value}));"],
    "description": "print(toString(...))"
  },
  "Wings async server (multi-thread)": {
    "prefix": "twingsa",
    "body": [
      "import \"wings\";",
      "",
      "func index_handler() {",
      "  return {\"hello\": \"world\"};",
      "}",
      "",
      "get(\"/\", \"index_handler\");",
      "listen_async(${1:8080});"
    ],
    "description": "Wings server with thread-per-connection (handler mutex serialised)"
  },
  "OpenAPI handler": {
    "prefix": "topenapi",
    "body": [
      "func openapi_handler() {",
      "  return wings_openapi(\"${1:My API}\", \"${2:1.0.0}\");",
      "}",
      "get(\"/openapi.json\", \"openapi_handler\");"
    ],
    "description": "Auto-generated OpenAPI 3.0 from Wings routes"
  },
  "Structured log (info)": {
    "prefix": "tloginfo",
    "body": ["log_info(\"${1:message}\");"],
    "description": "Wings JSON access log: {@timestamp, level: info, msg}"
  },
  "Structured log (error)": {
    "prefix": "tlogerror",
    "body": ["log_error(\"${1:message}\");"],
    "description": "Wings JSON access log: {@timestamp, level: error, msg}"
  },
  "Outbound HTTP GET": {
    "prefix": "thttpget",
    "body": [
      "import \"http_client\";",
      "json r = http_get(\"${1:http://example.com/}\");",
      "if (r[\"ok\"]) {",
      "  print(r[\"body\"]);",
      "}"
    ],
    "description": "Outbound HTTP GET via http_client"
  },
  "Outbound HTTP POST JSON": {
    "prefix": "thttppost",
    "body": [
      "import \"http_client\";",
      "json r = http_post_json(\"${1:http://example.com/}\", {\"${2:key}\": \"${3:value}\"});",
      "if (r[\"ok\"]) {",
      "  json data = r[\"data\"];",
      "  $0",
      "}"
    ],
    "description": "POST JSON, parse response.body via http_post_json"
  },
  "ORM model + CRUD": {
    "prefix": "torm",
    "body": [
      "import \"orm\";",
      "",
      "orm_open(\"${1:app.db}\");",
      "define_model(\"${2:users}\", {",
      "  \"id\":   \"INTEGER PRIMARY KEY AUTOINCREMENT\",",
      "  \"name\": \"TEXT NOT NULL\",",
      "  \"age\":  \"INTEGER\"",
      "});",
      "",
      "int id = orm_create(\"${2:users}\", {\"name\": \"${3:Hamza}\", \"age\": 23});",
      "json u = orm_find(\"${2:users}\", id);",
      "$0"
    ],
    "description": "Active-Record style ORM over SQLite"
  },
  "datetime now (ISO 8601)": {
    "prefix": "tnow",
    "body": ["str now = now_iso8601();"],
    "description": "Current UTC time as ISO 8601 string"
  },
  "regex capture groups": {
    "prefix": "trxc",
    "body": [
      "array g = regex_capture(\"${1:(\\\\w+)=(\\\\w+)}\", \"${2:k=v}\");",
      "if (length(g) > 0) {",
      "  $0",
      "}"
    ],
    "description": "regex_capture returns [whole, g1, g2, …] or []"
  },
  "CSV parse": {
    "prefix": "tcsv",
    "body": [
      "array rows = csv_parse(${1:source});",
      "for (array row in rows) {",
      "  $0",
      "}"
    ],
    "description": "RFC 4180 CSV parse — array of rows of strings"
  },
  "file_glob": {
    "prefix": "tglob",
    "body": [
      "array files = file_glob(\"${1:./*.tpr}\");",
      "for (str path in files) {",
      "  $0",
      "}"
    ],
    "description": "Shell-style file glob (`*` `?`)"
  },
  "Package manifest dependency": {
    "prefix": "tpkgdep",
    "body": ["${1:dep_name} = \"${2:0.1.0}\""],
    "description": "tulpar.toml [dependencies] entry"
  },
  "Arena scope": {
    "prefix": "tarena",
    "body": [
      "int wm = arena_save();",
      "$0",
      "arena_restore(wm);"
    ],
    "description": "Per-request arena scope (memory hygiene)"
  }
}
